# Copy this file to ".env" and fill in YOUR Supabase project values.
# Find them in your Supabase dashboard: Project Settings -> API.
# The anon (publishable) key is safe to expose in a deployed site; Row Level
# Security restricts it to authenticated reads.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
